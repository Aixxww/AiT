# AiT Environment Variables
# Copy to .env and edit as needed:  cp .env.example .env
# Keys are auto-generated on first run if not set.

# ── Server ──────────────────────────────────────────
AIT_BACKEND_PORT=8080
AIT_FRONTEND_PORT=3000
AIT_TIMEZONE=Asia/Shanghai

# ── Authentication ──────────────────────────────────
# JWT signing secret (auto-generated if empty)
# Generate: openssl rand -base64 32
JWT_SECRET=

# ── Encryption ──────────────────────────────────────
# AES-256 key for database encryption (Base64, 32 bytes)
# Generate: openssl rand -base64 32
DATA_ENCRYPTION_KEY=

# RSA 2048-bit PEM for client-server key exchange
# Auto-generated on first run if empty
RSA_PRIVATE_KEY=

# ── Security ────────────────────────────────────────
# Browser-side API key encryption (requires HTTPS or localhost)
TRANSPORT_ENCRYPTION=false

# ── Database ────────────────────────────────────────
# SQLite (default — zero config)
DB_TYPE=sqlite
DB_PATH=data/data.db

# PostgreSQL (uncomment to use)
# DB_TYPE=postgres
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=ait
# DB_PASSWORD=your_password_here
# DB_NAME=ait
# DB_SSLMODE=disable

# ── Optional: Market Data Providers ─────────────────
# ALPACA_API_KEY=
# ALPACA_SECRET_KEY=
# TWELVEDATA_API_KEY=
